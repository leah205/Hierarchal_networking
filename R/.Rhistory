ranksA$time_period = 1
ranksB$time_period = 2
ranksC$time_period = 3
all_ranks = rbind(ranksA, ranksB, ranksC)
ggplot(all_ranks, aes(x = time_period, y = ranks, color =  Var1)) +
scale_x_discrete(breaks = seq(1, 3, by = 1)) +
geom_bump()
#A_merged = merge(A, ranksA, by = "Var1")
ranksA$time_period = 1
ranksB$time_period = 2
ranksC$time_period = 3
all_ranks = rbind(ranksA, ranksB, ranksC)
ggplot(all_ranks, aes(x = time_period, y = ranks, color =  Var1)) +
scale_x_discrete(limits = c("1", "2", "3")) +
geom_bump()
#A_merged = merge(A, ranksA, by = "Var1")
ranksA$time_period = 1
ranksB$time_period = 2
ranksC$time_period = 3
all_ranks = rbind(ranksA, ranksB, ranksC)
ggplot(all_ranks, aes(x = time_period, y = ranks, color =  Var1)) +
scale_x_discrete(limits = c("1", "2", "3"),
expand = c(0, 0)) +
geom_bump()
#A_merged = merge(A, ranksA, by = "Var1")
ranksA$time_period = 1
ranksB$time_period = 2
ranksC$time_period = 3
all_ranks = rbind(ranksA, ranksB, ranksC)
ggplot(all_ranks, aes(x = time_period, y = ranks, color =  Var1)) +
scale_x_discrete(limits = c("1", "2", "3"),
expand = c(0, 0)) +
geom_bump() +
ggtitle("Rank Change Over Time") +
theme(
axis.text.x = element_text(size = 14),
axis.text.y = element_text(size = 14)
) + theme(
legend.text = element_text(size = 14)
)
#A_merged = merge(A, ranksA, by = "Var1")
ranksA$time_period = 1
ranksB$time_period = 2
ranksC$time_period = 3
all_ranks = rbind(ranksA, ranksB, ranksC)
ggplot(all_ranks, aes(x = time_period, y = ranks, color =  Var1)) +
scale_x_discrete(limits = c("1", "2", "3"),
expand = c(0, 0)) +
geom_bump() +
ggtitle("Rank Change Over Time") +
theme(
axis.text.x = element_text(size = 20),
axis.text.y = element_text(size = 20)
) + theme(
legend.text = element_text(size = 18)
)
