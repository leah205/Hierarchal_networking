create_table <- function(df){
ranksTableA <- df
ranksTableA$ranks <- round(ranksTableA$ranks, 3)
df %>%
dplyr::rename(Name = 1, Rank = ranks) %>%
knitr::kable(format = "html") %>%
kableExtra::kable_styling() %>%
kableExtra::column_spec(1:ncol(df), border_left = TRUE, border_right = TRUE) %>%
kableExtra::row_spec(nrow(df), extra_css = "border-bottom: 1px solid black;")
